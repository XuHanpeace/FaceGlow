# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

source 'https://mirrors.tuna.tsinghua.edu.cn/git/CocoaPods/Specs.git'

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'MyCrossPlatformApp' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  # Comment out or remove this block if you don't need tests
  # target 'MyCrossPlatformAppTests' do
  #   inherit! :complete
  #   # Pods for testing
  # end

  post_install do |installer|
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.1' # 匹配项目设置
        
        # 移除模拟器的 arm64 排除设置，让 Xcode 自动选择正确的架构
        config.build_settings.delete('EXCLUDED_ARCHS[sdk=iphonesimulator*]')
        
        # 生成dSYM文件配置
        config.build_settings['DEBUG_INFORMATION_FORMAT'] = 'dwarf-with-dsym'
        config.build_settings['GCC_GENERATE_DEBUGGING_SYMBOLS'] = 'YES'
        config.build_settings['STRIP_INSTALLED_PRODUCT'] = 'NO'
        
        # 添加 -ObjC 链接标志，这对 Objective-C 类别和 QCloud SDK 很重要
        config.build_settings['OTHER_LDFLAGS'] ||= ['$(inherited)']
        unless config.build_settings['OTHER_LDFLAGS'].include?('-ObjC')
          config.build_settings['OTHER_LDFLAGS'] << '-ObjC'
        end
        
        # 确保 Hermes 调试符号正确链接
        if target.name == 'React-jsinspector' || target.name.include?('hermes')
          unless config.build_settings['OTHER_LDFLAGS'].include?('-ObjC')
            config.build_settings['OTHER_LDFLAGS'] << '-ObjC'
          end
        end
      end
    end
    
    # 修复 xcconfig 文件中的 EXCLUDED_ARCHS 设置
    installer.pods_project.build_configurations.each do |config|
      config.build_settings.delete('EXCLUDED_ARCHS[sdk=iphonesimulator*]')
    end
    
    # https://github.com/facebook/react-native/blob/main/packages/react-native/scripts/react_native_pods.rb#L197-L202
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )
    
    # 在 react_native_post_install 之后，直接修改所有生成的 xcconfig 文件，移除 EXCLUDED_ARCHS 设置
    # 这必须在最后执行，因为 xcconfig 文件是在 react_native_post_install 中生成的
    Dir.glob(File.join(installer.sandbox.root, 'Target Support Files', '**', '*.xcconfig')).each do |xcconfig_path|
      if File.exist?(xcconfig_path)
        xcconfig_content = File.read(xcconfig_path)
        original_content = xcconfig_content.dup
        # 移除 EXCLUDED_ARCHS 行（包括前后可能有空行的情况）
        xcconfig_content.gsub!(/^EXCLUDED_ARCHS\[sdk=iphonesimulator\*\] = arm64\s*$\n?/, '')
        if xcconfig_content != original_content
          File.write(xcconfig_path, xcconfig_content)
          puts "✅ 已修复: #{xcconfig_path}"
        end
      end
    end
    
    # 修复Hermes dSYM问题并确保调试符号链接
    installer.pods_project.targets.each do |target|
      if target.name == 'hermes-engine'
        target.build_configurations.each do |config|
          config.build_settings['DEBUG_INFORMATION_FORMAT'] = 'dwarf-with-dsym'
          config.build_settings['GCC_GENERATE_DEBUGGING_SYMBOLS'] = 'YES'
          config.build_settings['STRIP_INSTALLED_PRODUCT'] = 'NO'
        end
      end
      
      # 确保 React-jsinspector 正确链接
      if target.name == 'React-jsinspector'
        target.build_configurations.each do |config|
          config.build_settings['OTHER_LDFLAGS'] ||= ['$(inherited)']
          config.build_settings['OTHER_LDFLAGS'] << '-ObjC'
        end
      end
    end
  end

  pod 'SocketRocket', '= 0.7.1'
  pod 'RNVectorIcons', :path => '../node_modules/react-native-vector-icons'
  pod 'DoubleConversion', :podspec => '../node_modules/react-native/third-party-podspecs/DoubleConversion.podspec'
  
  # 腾讯云COS SDK
  pod 'QCloudCOSXML'
end
